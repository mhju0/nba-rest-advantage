# Copy to .env.local and fill in values. Never commit real secrets.

# Server-only: Supabase Postgres (Drizzle). Do NOT use NEXT_PUBLIC_ prefix.
DATABASE_URL=

# Client + server: Supabase project (Realtime). Must be NEXT_PUBLIC_ for browser access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vercel Cron: Authorization: Bearer <CRON_SECRET> for GET /api/cron/update
CRON_SECRET=
